APP_ENV=development

POSTGRES_DB=sara_knowledge
POSTGRES_USER=sara
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://sara:change_me@postgres:5432/sara_knowledge

REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=sara_minio
MINIO_SECRET_KEY=change_me
MINIO_USE_SSL=false
MINIO_BUCKET=sara-assets

JWT_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

API_PORT=4000
ADMIN_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
WORDPRESS_WEBHOOK_SECRET=change_me
WEBHOOK_SIGNING_SECRET=change_me
MAX_UPLOAD_SIZE_MB=100
